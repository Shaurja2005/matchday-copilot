# MatchDay Copilot — Environment Variables

# ========================
# GenAI / LLM
# ========================

# Gemini API Key (Required for live mode)
GEMINI_API_KEY=sk-gemini-your-key-here

# Set to "mock" to use stubbed AI responses without a real API key
GENAI_MODE=mock

# ========================
# Server
# ========================
PORT=5000
NODE_ENV=development

# Allowed CORS origin (your frontend URL)
FRONTEND_URL=http://localhost:3000

# ========================
# Rate Limiting
# ========================
# Max chat requests per window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ========================
# Session / Cache
# ========================
SESSION_SECRET=change-me-to-a-random-secret
# In-memory cache TTL for FAQ answers (seconds)
CACHE_TTL_SECONDS=300
